# ─────────────────────────────────────────────────────────────
# CodeSheriff – Environment Variables Template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# GitHub Personal Access Token
# Scopes required: repo (read PR diffs + write review comments)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Shared secret for HMAC-SHA256 verification of GitHub webhooks.
# Set the same value in your GitHub repository → Settings → Webhooks.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your_random_hex_secret_here

# Google API key – used by the analysis-service to call Gemini.
# Create one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── Shadow mode ──────────────────────────────────────────────
# When set to "true", reviews are fully analysed and stored in the DB
# but NO comments are posted back to GitHub.
# Useful for validating output quality before going live.
SHADOW_MODE=false

# ─── Claude model ────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-5

# ─── Database ────────────────────────────────────────────────
# SQLite (default – no extra setup needed):
DATABASE_URL=sqlite:///./codesheriff.db

# PostgreSQL example (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/codesheriff

# ─── Inter-service URLs ───────────────────────────────────────
# Override these when deploying services on separate hosts.
ANALYSIS_SERVICE_URL=http://localhost:8002
COMMENT_SERVICE_URL=http://localhost:8003
